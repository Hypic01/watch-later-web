{
  "name": "watch-later-web",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run build:web && npm run build:collector && node server/index.js",
    "dev": "node server/index.js",
    "dev:web": "vite --config web/vite.config.js",
    "build:web": "vite build --config web/vite.config.js",
    "build:collector": "node collector/build-snippet.js",
    "build:extension": "node extension/build-extension.js",
    "migrate": "node server/migrate.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "express": "^4.19.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.14",
    "@supabase/supabase-js": "^2.47.10",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
