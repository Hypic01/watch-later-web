# ---- Production (all required) ----
# DATABASE_URL=postgresql://...          # Supabase: use the Supavisor pooled connection string
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_ANON_KEY=eyJ...               # also set VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY at build time
# SUPABASE_JWT_SECRET=                   # only for legacy HS256 projects; omit to use JWKS
# ANTHROPIC_API_KEY=sk-ant-...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# APP_URL=https://your-domain.com
# ADMIN_EMAILS=doldorijw@gmail.com

# ---- Knobs (defaults shown) ----
# PORT=4400
# FREE_VIDEO_QUOTA=100
# BUDGET_USD=100
# IMPORTS_PER_HOUR=5
# CHUNK_SIZE=25
# BATCH_THRESHOLD=500
# CLASSIFY_MODEL=claude-haiku-4-5
# BETA_ALLOWLIST=friend@example.com,friend2@example.com
# EXTENSION_IDS=abcdefghijklmnopabcdefghijklmnop,ponmlkjihgfedcbaponmlkjihgfedcba
# VITE_EXTENSION_ID=abcdefghijklmnopabcdefghijklmnop  # comma separated client IDs are supported

# ---- Local dev (zero accounts needed) ----
# DEV_FAKE_AUTH=1                        # sign in with any email
# FAKE_LLM=1                             # deterministic classification, zero API cost
